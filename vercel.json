{
  "version": 2,
  "name": "paperclip",
  "builds": [
    {
      "src": "server/dist/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/dist/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "PAPERCLIP_DEPLOYMENT_MODE": "authenticated",
    "PAPERCLIP_DEPLOYMENT_EXPOSURE": "private",
    "SERVE_UI": "true"
  },
  "regions": ["sin1"],
  "functions": {
    "server/dist/index.js": {
      "maxDuration": 60
    }
  }
}
